generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  password           String
  name               String?
  companyName        String?
  phone              String?
  role               String         @default("CLIENT")
  permissions        String         @default("[]")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  resetToken         String?
  resetTokenExpiry   DateTime?
  isAuthorized       Boolean        @default(true)
  tempPassword       String?
  mustChangePassword Boolean        @default(false)
  alsoNotifys        AlsoNotify[]
  billsOfLading      BillOfLading[]
  cities             City[]
  consignees         Consignee[]
  forwarders         Forwarder[]
  freightBuyers      FreightBuyer[]
  goods              Goods[]
  hscodes            HSCode[]
  notifys            Notify[]
  packageTypes       PackageType[]
  ports              Port[]
  shippers           Shipper[]
  typesReleased      TypeReleased[]
  typesTc            TypeTc[]
  vessels            Vessel[]
  voyages            Voyage[]
}

model HSCode {
  id          String   @id @default(uuid())
  code        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  @@unique([code, userId])
}

model Shipper {
  id            String         @id @default(uuid())
  name          String
  address       String
  country       String
  city          String
  phone         String
  email         String
  vat           String?
  eori          String?
  bin           String?
  usci          String?
  saveStatus    String         @default("VALIDATED")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userId        String
  billsOfLading BillOfLading[]
  user          User           @relation(fields: [userId], references: [id])
}

model Consignee {
  id            String         @id @default(uuid())
  name          String
  address       String
  country       String
  city          String
  phone         String
  email         String
  vat           String?
  eori          String?
  bin           String?
  usci          String?
  saveStatus    String         @default("VALIDATED")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userId        String
  billsOfLading BillOfLading[]
  user          User           @relation(fields: [userId], references: [id])
}

model Notify {
  id            String         @id @default(uuid())
  name          String
  address       String
  country       String
  city          String
  phone         String
  email         String
  vat           String?
  eori          String?
  bin           String?
  usci          String?
  saveStatus    String         @default("VALIDATED")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userId        String
  billsOfLading BillOfLading[]
  user          User           @relation(fields: [userId], references: [id])
}

model AlsoNotify {
  id            String         @id @default(uuid())
  name          String
  address       String
  country       String
  city          String
  phone         String
  email         String
  vat           String?
  eori          String?
  bin           String?
  usci          String?
  saveStatus    String         @default("VALIDATED")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  billsOfLading BillOfLading[]
}

model Forwarder {
  id            String         @id @default(uuid())
  name          String
  address       String
  country       String
  city          String
  phone         String
  email         String
  vat           String?
  eori          String?
  bin           String?
  usci          String?
  saveStatus    String         @default("VALIDATED")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userId        String
  billsOfLading BillOfLading[]
  user          User           @relation(fields: [userId], references: [id])
}

model FreightBuyer {
  id            String         @id @default(uuid())
  name          String
  address       String
  country       String
  city          String
  phone         String
  email         String
  vat           String?
  eori          String?
  bin           String?
  usci          String?
  saveStatus    String         @default("VALIDATED")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userId        String
  billsOfLading BillOfLading[]
  user          User           @relation(fields: [userId], references: [id])
}

model Goods {
  id            String         @id @default(uuid())
  description   String
  hsCode        String
  declNo        String
  saveStatus    String         @default("VALIDATED")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userId        String
  billsOfLading BillOfLading[]
  user          User           @relation(fields: [userId], references: [id])
}

model Port {
  id        String   @id @default(uuid())
  name      String
  code      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model City {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model TypeReleased {
  id            String         @id @default(uuid())
  name          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userId        String
  billsOfLading BillOfLading[]
  user          User           @relation(fields: [userId], references: [id])
}

model BillOfLading {
  id              String        @id @default(uuid())
  bookingNumber   String
  contractNumber  String
  saveStatus      String        @default("DRAFT")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  correctionCount Int           @default(0)
  originalData    Json?
  userId          String
  portCountryText String?
  portCityText    String?
  typeReleasedId  String?
  descriptionGoods String?
  hsCode          String?
  shipperId       String?
  consigneeId     String?
  notifyId        String?
  alsoNotifyId    String?
  forwarderId     String?
  freightBuyerId  String?
  goodsId         String?
  vesselId        String?
  voyageId        String?
  alsoNotify      AlsoNotify?   @relation(fields: [alsoNotifyId], references: [id])
  consignee       Consignee?    @relation(fields: [consigneeId], references: [id])
  forwarder       Forwarder?    @relation(fields: [forwarderId], references: [id])
  freightBuyer    FreightBuyer? @relation(fields: [freightBuyerId], references: [id])
  goods           Goods?        @relation(fields: [goodsId], references: [id])
  notify          Notify?       @relation(fields: [notifyId], references: [id])
  shipper         Shipper?      @relation(fields: [shipperId], references: [id])
  typeReleased    TypeReleased? @relation(fields: [typeReleasedId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
  vessel          Vessel?       @relation(fields: [vesselId], references: [id])
  voyage          Voyage?       @relation(fields: [voyageId], references: [id])
  containers      Container[]
}

model Vessel {
  id            String         @id @default(uuid())
  name          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userId        String
  billsOfLading BillOfLading[]
  user          User           @relation(fields: [userId], references: [id])
  voyages       Voyage[]

  @@unique([name, userId])
}

model Voyage {
  id               String            @id @default(uuid())
  number           String
  etdDate          DateTime?
  etaDate          DateTime?
  userId           String
  vesselId         String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  billsOfLading    BillOfLading[]
  rotationBookings RotationBooking[]
  user             User              @relation(fields: [userId], references: [id])
  vessel           Vessel            @relation(fields: [vesselId], references: [id], onDelete: Cascade)
}

model RotationBooking {
  id        String   @id @default(uuid())
  number    String   // Booking number
  voyageId  String
  voyage    Voyage   @relation(fields: [voyageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([number, voyageId])
}

model Container {
  id             String       @id @default(uuid())
  containerNum   String
  typeTc         String?
  sealNum        String?
  count          Int?
  packageType    String?
  grossWeight    Float?
  netWeight      Float?
  volume         Float?
  billOfLadingId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  billOfLading   BillOfLading @relation(fields: [billOfLadingId], references: [id], onDelete: Cascade)
}

model TypeTc {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@unique([name, userId])
}

model PackageType {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@unique([name, userId])
}

model GlobalCountry {
  id        String       @id @default(uuid())
  name      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  ports     GlobalPort[]
}

model GlobalPort {
  id        String        @id @default(uuid())
  name      String
  code      String?
  countryId String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  country   GlobalCountry @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([name, countryId])
}
